# Database
DATABASE_URL="file:./dev.db"

# Google Maps API (server-side: Distance Matrix, Directions, Places, Geocoding)
GOOGLE_MAPS_API_KEY="your_google_maps_api_key_here"

# Google Maps API (client-side: Maps JavaScript API for the Route Planner map embed)
# This key must have the Maps JavaScript API enabled in Google Cloud Console.
# Restrict it to your domain via HTTP referrer restrictions for security.
# Required APIs to enable in GCP: Maps JavaScript API, Directions API, Places API, Geocoding API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your_google_maps_api_key_here"

# Maintenance
MAINTENANCE_KEY="your_secret_maintenance_key_here"

# Default Home Location (used as the starting point)
# Format: latitude,longitude
# Example below: Adelaide CBD, South Australia
NEXT_PUBLIC_HOME_LATITUDE=-34.9285
NEXT_PUBLIC_HOME_LONGITUDE=138.6007
